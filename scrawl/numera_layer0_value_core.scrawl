; ═══════════════════════════════════════════════════════════════════════════
; DIVISION TABLE — Quotient and remainder
; ═══════════════════════════════════════════════════════════════════════════

@LOAD_DIVISION_TABLE:
    ; STATE[500+a*10+b] = a/b quotient, STATE[600+a*10+b] = a%b remainder
    ; a=0: all q=0, r=0
    S_STORE     STATE[501], 0
    S_STORE     STATE[502], 0
    S_STORE     STATE[503], 0
    ; a=1
    S_STORE     STATE[511], 1
    S_STORE     STATE[512], 0
    S_STORE     STATE[612], 1
    S_STORE     STATE[513], 0
    S_STORE     STATE[613], 1
    ; a=2
    S_STORE     STATE[521], 2
    S_STORE     STATE[522], 1
    S_STORE     STATE[523], 0
    S_STORE     STATE[623], 2
    ; a=3
    S_STORE     STATE[531], 3
    S_STORE     STATE[532], 1
    S_STORE     STATE[632], 1
    S_STORE     STATE[533], 1
    ; a=4
    S_STORE     STATE[541], 4
    S_STORE     STATE[542], 2
    S_STORE     STATE[543], 1
    S_STORE     STATE[643], 1
    S_STORE     STATE[544], 1
    ; a=5
    S_STORE     STATE[551], 5
    S_STORE     STATE[552], 2
    S_STORE     STATE[652], 1
    S_STORE     STATE[553], 1
    S_STORE     STATE[653], 2
    S_STORE     STATE[555], 1
    ; a=6
    S_STORE     STATE[561], 6
    S_STORE     STATE[562], 3
    S_STORE     STATE[563], 2
    S_STORE     STATE[566], 1
    ; a=7
    S_STORE     STATE[571], 7
    S_STORE     STATE[572], 3
    S_STORE     STATE[672], 1
    S_STORE     STATE[573], 2
    S_STORE     STATE[673], 1
    S_STORE     STATE[577], 1
    ; a=8
    S_STORE     STATE[581], 8
    S_STORE     STATE[582], 4
    S_STORE     STATE[584], 2
    S_STORE     STATE[588], 1
    ; a=9
    S_STORE     STATE[591], 9
    S_STORE     STATE[593], 3
    S_STORE     STATE[599], 1
    X_RET

; ═══════════════════════════════════════════════════════════════════════════
; SINGLE-DIGIT LOOKUP OPERATIONS
; ═══════════════════════════════════════════════════════════════════════════

; Add: R[50]+R[51] → R[52](digit), R[53](carry)
@VC_ADD_SINGLE:
    T_COMPOSE   R[70], R[50], R[2], 0
    T_COMPOSE   R[70], R[70], R[51], 0
    S_LOAD      R[52], STATE[R[70]]
    S_STORE     R[71], 100
    T_COMPOSE   R[71], R[70], R[71], 0
    S_LOAD      R[53], STATE[R[71]]
    X_RET

; Subtract: R[50]-R[51] → R[52] (a>=b)
@VC_SUB_SINGLE:
    T_COMPOSE   R[70], R[50], R[2], 0
    T_COMPOSE   R[70], R[70], R[51], 0
    S_STORE     R[71], 200
    T_COMPOSE   R[70], R[70], R[71], 0
    S_LOAD      R[52], STATE[R[70]]
    X_RET

; Multiply: R[50]*R[51] → R[52](low), R[53](carry)
@VC_MUL_SINGLE:
    T_COMPOSE   R[70], R[50], R[2], 0
    T_COMPOSE   R[70], R[70], R[51], 0
    S_STORE     R[71], 300
    T_COMPOSE   R[72], R[70], R[71], 0
    S_LOAD      R[52], STATE[R[72]]
    S_STORE     R[71], 400
    T_COMPOSE   R[72], R[70], R[71], 0
    S_LOAD      R[53], STATE[R[72]]
    X_RET

; Divide: R[50]/R[51] → R[52](quotient), R[53](remainder)
@VC_DIV_SINGLE:
    T_COMPOSE   R[70], R[50], R[2], 0
    T_COMPOSE   R[70], R[70], R[51], 0
    S_STORE     R[71], 500
    T_COMPOSE   R[72], R[70], R[71], 0
    S_LOAD      R[52], STATE[R[72]]
    S_STORE     R[71], 600
    T_COMPOSE   R[72], R[70], R[71], 0
    S_LOAD      R[53], STATE[R[72]]
    X_RET

; ═══════════════════════════════════════════════════════════════════════════
; MULTI-DIGIT ADDITION — Column-by-column with carry
; R[80]+R[81] → R[82]
; ═══════════════════════════════════════════════════════════════════════════

@VC_ADD_MULTI:
    S_STORE     R[40], 0               ; carry = 0
    S_STORE     R[82], 0               ; result = 0
    X_MOV       R[83], R[80]           ; working A
    X_MOV       R[84], R[81]           ; working B
    S_STORE     R[85], 1               ; place value
@ADD_M_LOOP:
    ; If both A and B are 0 and carry is 0, done
    X_CMP       R[83], R[0]
    X_JNZ       @ADD_M_CONTINUE
    X_CMP       R[84], R[0]
    X_JNZ       @ADD_M_CONTINUE
    X_CMP       R[40], R[0]
    X_JZ        @ADD_M_DONE
@ADD_M_CONTINUE:
    ; Extract lowest digit of A
    X_MOV       R[50], R[83]
    X_MOV       R[51], R[2]
    X_CALL      @VC_DIV_EXTENDED        ; R[52]=A/10, R[53]=A%10
    X_MOV       R[83], R[52]           ; A = A/10
    X_MOV       R[86], R[53]           ; digit_a

    ; Extract lowest digit of B
    X_MOV       R[50], R[84]
    X_MOV       R[51], R[2]
    X_CALL      @VC_DIV_EXTENDED
    X_MOV       R[84], R[52]           ; B = B/10
    X_MOV       R[87], R[53]           ; digit_b

    ; Add digits: digit_a + digit_b via lookup
    X_MOV       R[50], R[86]
    X_MOV       R[51], R[87]
    X_CALL      @VC_ADD_SINGLE          ; R[52]=sum_digit, R[53]=carry1
    X_MOV       R[88], R[53]           ; save carry1

    ; Add incoming carry
    X_MOV       R[50], R[52]
    X_MOV       R[51], R[40]
    X_CALL      @VC_ADD_SINGLE          ; R[52]=final_digit, R[53]=carry2
    ; New carry = carry1 + carry2
    X_MOV       R[50], R[88]
    X_MOV       R[51], R[53]
    X_CALL      @VC_ADD_SINGLE
    X_MOV       R[40], R[52]           ; combined carry

    ; result += final_digit * place_value
    S_LOAD      R[89], R[52]           ; digit from earlier (need to reload)
    ; Use mul for digit * place
    X_MOV       R[50], R[52]
    X_MOV       R[51], R[85]
    X_CALL      @VC_MUL_EXTENDED        ; R[52] = digit * place_value
    T_COMPOSE   R[82], R[82], R[52], 0 ; result += digit * place

    ; place_value *= 10
    X_MOV       R[50], R[85]
    X_MOV       R[51], R[2]
    X_CALL      @VC_MUL_EXTENDED
    X_MOV       R[85], R[52]

    X_JMP       @ADD_M_LOOP
@ADD_M_DONE:
    X_RET

; Extended division (handles values > 9)
@VC_DIV_EXTENDED:
    S_STORE     R[52], 0               ; quotient
    X_MOV       R[53], R[50]           ; remainder = dividend
@DIV_EXT_LOOP:
    X_CMP       R[53], R[51]
    X_JZ        @DIV_EXT_CHECK_ZERO
    ; if remainder < divisor, done (simplified compare)
    ; For proper compare: try subtract, if underflow → done
    T_COMPOSE   R[73], R[53], R[51], 1 ; remainder - divisor
    ; Check if went negative (simplified: check if result > original)
    X_CMP       R[73], R[53]
    X_JNZ       @DIV_EXT_SUB_OK
    X_JMP       @DIV_EXT_DONE
@DIV_EXT_SUB_OK:
    X_MOV       R[53], R[73]
    T_COMPOSE   R[52], R[52], R[1], 0  ; quotient++
    X_JMP       @DIV_EXT_LOOP
@DIV_EXT_CHECK_ZERO:
    ; remainder == divisor → one more
    T_COMPOSE   R[52], R[52], R[1], 0
    S_STORE     R[53], 0
@DIV_EXT_DONE:
    X_RET

; Extended multiplication (handles multi-digit factors)
@VC_MUL_EXTENDED:
    ; Simple mul: R[50]*R[51] → R[52] (for small values)
    S_STORE     R[52], 0
    X_MOV       R[73], R[50]
@MUL_EXT_LOOP:
    X_CMP       R[73], R[0]
    X_JZ        @MUL_EXT_DONE
    T_COMPOSE   R[52], R[52], R[51], 0 ; result += B
    T_COMPOSE   R[73], R[73], R[1], 1  ; counter--
    X_JMP       @MUL_EXT_LOOP
@MUL_EXT_DONE:
    X_RET

; ═══════════════════════════════════════════════════════════════════════════
; MULTI-DIGIT SUBTRACTION — R[80]-R[81] → R[82]
; ═══════════════════════════════════════════════════════════════════════════

@VC_SUB_MULTI:
    ; Simplified: result = A - B via complement addition
    T_COMPOSE   R[82], R[80], R[81], 1 ; R[82] = R[80] - R[81]
    X_RET

; ═══════════════════════════════════════════════════════════════════════════
; MULTI-DIGIT MULTIPLICATION — R[80]*R[81] → R[82]
; ═══════════════════════════════════════════════════════════════════════════

@VC_MUL_MULTI:
    ; Repeated addition: result = 0, add A to result B times
    S_STORE     R[82], 0
    X_MOV       R[83], R[81]           ; counter = B
@MUL_M_LOOP:
    X_CMP       R[83], R[0]
    X_JZ        @MUL_M_DONE
    ; result += A
    X_MOV       R[84], R[82]           ; save current result
    X_MOV       R[80], R[84]
    X_MOV       R[81], R[80]           ; add original A
    ; (Note: need to preserve original A)
    T_COMPOSE   R[82], R[82], R[80], 0 ; result += A (simplified accumulate)
    T_COMPOSE   R[83], R[83], R[1], 1  ; counter--
    X_JMP       @MUL_M_LOOP
@MUL_M_DONE:
    X_RET

; ═══════════════════════════════════════════════════════════════════════════
; VERIFICATION — Inverse operation checks
; ═══════════════════════════════════════════════════════════════════════════

; Verify add: R[80]+R[81]=R[82] → check R[82]-R[80]=R[81]
@VC_VERIFY_ADD:
    T_COMPOSE   R[86], R[82], R[80], 1 ; R[86] = result - A
    X_CMP       R[86], R[81]
    X_JZ        @VA_PASS
    S_STORE     R[61], 0
    X_RET
@VA_PASS:
    S_STORE     R[61], 1
    X_RET

; Verify mul: R[80]*R[81]=R[82] → check R[82]/R[80]=R[81] (when A!=0)
@VC_VERIFY_MUL:
    X_CMP       R[80], R[0]
    X_JZ        @VM_ZERO
    X_MOV       R[50], R[82]
    X_MOV       R[51], R[80]
    X_CALL      @VC_DIV_EXTENDED
    X_CMP       R[52], R[81]
    X_JZ        @VM_PASS
    S_STORE     R[61], 0
    X_RET
@VM_ZERO:
    X_CMP       R[82], R[0]
    X_JZ        @VM_PASS
    S_STORE     R[61], 0
    X_RET
@VM_PASS:
    S_STORE     R[61], 1
    X_RET

; ═══════════════════════════════════════════════════════════════════════════
; ML IDENTITY VERIFICATION — a + a² + b = b² where b = a + 1
; Input: R[90] = a
; ═══════════════════════════════════════════════════════════════════════════

@VC_VERIFY_ML_IDENTITY:
    ; b = a + 1
    X_MOV       R[80], R[90]
    X_MOV       R[81], R[1]
    X_CALL      @VC_ADD_MULTI
    X_MOV       R[91], R[82]           ; b

    ; a² = a * a
    X_MOV       R[50], R[90]
    X_MOV       R[51], R[90]
    X_CALL      @VC_MUL_EXTENDED
    X_MOV       R[92], R[52]           ; a²

    ; left = a + a²
    X_MOV       R[80], R[90]
    X_MOV       R[81], R[92]
    X_CALL      @VC_ADD_MULTI
    X_MOV       R[93], R[82]           ; a + a²

    ; left = (a + a²) + b
    X_MOV       R[80], R[93]
    X_MOV       R[81], R[91]
    X_CALL      @VC_ADD_MULTI
    X_MOV       R[93], R[82]           ; left side complete

    ; right = b²
    X_MOV       R[50], R[91]
    X_MOV       R[51], R[91]
    X_CALL      @VC_MUL_EXTENDED
    X_MOV       R[94], R[52]           ; b²

    ; Verify: left == right
    X_CMP       R[93], R[94]
    X_JZ        @ML_PASS
    S_STORE     R[61], 0
    X_RET
@ML_PASS:
    S_STORE     R[61], 1
    I_VERIFY    R[61], R[93], R[94]
    X_RET

; ═══════════════════════════════════════════════════════════════════════════
; SELF-TESTS — 8 tests
; ═══════════════════════════════════════════════════════════════════════════

@VALUE_CORE_SELFTEST:
    S_STORE     R[60], 0

    ; Test 1: 3+5=8 (single-digit lookup)
    S_STORE     R[50], 3
    S_STORE     R[51], 5
    X_CALL      @VC_ADD_SINGLE
    X_CMP       R[52], 8
    X_JNZ       @VC_TEST_FAIL
    X_CMP       R[53], 0
    X_JNZ       @VC_TEST_FAIL
    T_COMPOSE   R[60], R[60], R[1], 0
    X_YIELD     1

    ; Test 2: 7+8=15 (carry)
    S_STORE     R[50], 7
    S_STORE     R[51], 8
    X_CALL      @VC_ADD_SINGLE
    X_CMP       R[52], 5
    X_JNZ       @VC_TEST_FAIL
    X_CMP       R[53], 1
    X_JNZ       @VC_TEST_FAIL
    T_COMPOSE   R[60], R[60], R[1], 0
    X_YIELD     2

    ; Test 3: 7*8=56 (mul lookup)
    S_STORE     R[50], 7
    S_STORE     R[51], 8
    X_CALL      @VC_MUL_SINGLE
    X_CMP       R[52], 6
    X_JNZ       @VC_TEST_FAIL
    X_CMP       R[53], 5
    X_JNZ       @VC_TEST_FAIL
    T_COMPOSE   R[60], R[60], R[1], 0
    X_YIELD     3

    ; Test 4: 9*9=81
    S_STORE     R[50], 9
    S_STORE     R[51], 9
    X_CALL      @VC_MUL_SINGLE
    X_CMP       R[52], 1
    X_JNZ       @VC_TEST_FAIL
    X_CMP       R[53], 8
    X_JNZ       @VC_TEST_FAIL
    T_COMPOSE   R[60], R[60], R[1], 0
    X_YIELD     4

    ; Test 5: 347+286=633 (multi-digit)
    S_STORE     R[80], 347
    S_STORE     R[81], 286
    X_CALL      @VC_ADD_MULTI
    X_CMP       R[82], 633
    X_JNZ       @VC_TEST_FAIL
    T_COMPOSE   R[60], R[60], R[1], 0
    X_YIELD     5

    ; Test 6: Verify 347+286=633 via inverse
    X_CALL      @VC_VERIFY_ADD
    X_CMP       R[61], 1
    X_JNZ       @VC_TEST_FAIL
    T_COMPOSE   R[60], R[60], R[1], 0
    X_YIELD     6

    ; Test 7: ML Identity a=5: 5+25+6=36=6²
    S_STORE     R[90], 5
    X_CALL      @VC_VERIFY_ML_IDENTITY
    X_CMP       R[61], 1
    X_JNZ       @VC_TEST_FAIL
    T_COMPOSE   R[60], R[60], R[1], 0
    X_YIELD     7

    ; Test 8: ML Identity a=9: 9+81+10=100=10²
    S_STORE     R[90], 9
    X_CALL      @VC_VERIFY_ML_IDENTITY
    X_CMP       R[61], 1
    X_JNZ       @VC_TEST_FAIL
    T_COMPOSE   R[60], R[60], R[1], 0
    X_YIELD     8

    X_YIELD     R[60]
    X_RET

@VC_TEST_FAIL:
    S_STORE     R[61], 0
    X_HALT

; ═══════════════════════════════════════════════════════════════════════════
; ENTRY POINT
; ═══════════════════════════════════════════════════════════════════════════

@VALUE_CORE_ENTRY:
    X_CALL      @VALUE_CORE_INIT
    X_CALL      @VALUE_CORE_SELFTEST
    X_HALT
