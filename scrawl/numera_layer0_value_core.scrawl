; ============================================================================
; NUMERA v0.1.0 — Layer 0: Value Core
; SCRAWL Implementation (ROSETTA Transpiler Format)
; ============================================================================
;
; The Value Core: 400 pre-computed arithmetic facts (addition, subtraction,
; multiplication, division) for digits 0-9. Multi-digit arithmetic algorithms
; decompose operations into single-digit lookups with carry/borrow propagation.
;
; No native arithmetic is used for foundational computation.
; 3 + 5 is RETRIEVED as a fact, not calculated.
;
; Built on SCRAWL v1.0 ISA (84 opcodes, 6 domains)
; Foundation: ML Identity — a + a² + b = b²  where b = a + 1
; Discovered by M. L. McKnight, Raymond High School, 1999
;
; Register Map:
;   R[0]       = Zero constant
;   R[1]       = One constant
;   R[2]       = Ten constant (base)
;   R[3]       = Hundred constant
;   R[10-19]   = Working registers (operand A digits)
;   R[20-29]   = Working registers (operand B digits)
;   R[30-39]   = Working registers (result digits)
;   R[40]      = Carry register
;   R[41]      = Borrow register
;   R[42]      = Digit count A
;   R[43]      = Digit count B
;   R[44]      = Result digit count
;   R[45]      = Sign register (0=positive, 1=negative)
;   R[50]      = Lookup operand A (0-9)
;   R[51]      = Lookup operand B (0-9)
;   R[52]      = Lookup result
;   R[53]      = Lookup carry/remainder
;   R[60]      = Test counter
;   R[61]      = Verification status (1=pass, 0=fail)
;   R[80-85]   = Multi-digit working registers
;   R[90-94]   = ML Identity working registers
;
; State Memory Map:
;   STATE[0000-0099]   = Addition table     (a*10+b → sum digit)
;   STATE[0100-0199]   = Addition carry     (a*10+b → carry)
;   STATE[0200-0299]   = Subtraction table  (a*10+b → diff, a>=b)
;   STATE[0300-0399]   = Multiplication low (a*10+b → product low digit)
;   STATE[0400-0499]   = Multiplication hi  (a*10+b → product high digit)
;   STATE[0500-0599]   = Division quotient  (a*10+b → quotient, b!=0)
;   STATE[0600-0699]   = Division remainder (a*10+b → remainder, b!=0)
;
; © 2026 ML Innovations LLC. All Rights Reserved.
; Contact: M. L. McKnight | ml.innovations.research.lab@gmail.com
;          Pheba, Mississippi
; ============================================================================

; ═══════════════════════════════════════════════════════════════════════════
; INITIALIZATION — Load all 400 arithmetic facts into state
; ═══════════════════════════════════════════════════════════════════════════

@VALUE_CORE_INIT:
    S_STORE     R[0], 0
    S_STORE     R[1], 1
    S_STORE     R[2], 10
    S_STORE     R[3], 100
    X_CALL      @LOAD_ADDITION_TABLE
    X_CALL      @LOAD_SUBTRACTION_TABLE
    X_CALL      @LOAD_MULTIPLICATION_TABLE
    X_CALL      @LOAD_DIVISION_TABLE
    X_RET

; ═══════════════════════════════════════════════════════════════════════════
; ADDITION TABLE — 100 facts, 0+0 through 9+9
; STATE[a*10+b] = (a+b) mod 10
; STATE[100+a*10+b] = (a+b) / 10 (carry, 0 or 1)
; ═══════════════════════════════════════════════════════════════════════════

@LOAD_ADDITION_TABLE:
    ; Row 0: 0+b = b (no carries)
    S_STORE     STATE[0], 0
    S_STORE     STATE[1], 1
    S_STORE     STATE[2], 2
    S_STORE     STATE[3], 3
    S_STORE     STATE[4], 4
